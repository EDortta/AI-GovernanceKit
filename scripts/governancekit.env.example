# Template for ~/.config/wa-hub/governancekit.env (local-only, never commit).
# Copy to ~/.config/wa-hub/governancekit.env and fill in the real values:
#   mkdir -p ~/.config/wa-hub
#   cp scripts/governancekit.env.example ~/.config/wa-hub/governancekit.env
#   chmod 600 ~/.config/wa-hub/governancekit.env

# wa-hub base URL (default if unset: http://localhost:8090)
WA_HUB_URL=http://localhost:8090

# Required — destination JID for operator notifications.
WA_HUB_DEST=[WA_HUB_DEST]@s.whatsapp.net

# Required — provisioned wa-hub client API key (X-Api-Key).
WA_HUB_KEY=[WA_HUB_KEY]
